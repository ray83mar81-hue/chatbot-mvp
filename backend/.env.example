# === AI Provider ===
# Default: OpenAI-compatible endpoint (works with OpenRouter, OpenAI, Groq, Together).
# Unlocks cheap models like gpt-4o-mini, gemini-2.5-flash, llama-3.3.
AI_PROVIDER=openai
AI_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=sk-or-v1-xxxx
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Alternative models (change AI_MODEL to one of these):
#   openai/gpt-4o-mini              ← cheapest good option (~$0.15 in / $0.60 out per M)
#   google/gemini-2.5-flash         ← great for multi-language (~$0.30 / $2.50)
#   anthropic/claude-haiku-4.5      ← Claude quality, cheaper than Sonnet (~$1 / $5)
#   anthropic/claude-sonnet-4       ← highest quality, most expensive (~$3 / $15)
#   meta-llama/llama-3.3-70b-instruct ← cheapest overall (~$0.13 / $0.40)

# Legacy Anthropic SDK path (only needed if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_BASE_URL=

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://user:pass@localhost:5432/chatbot

# === Auth ===
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_MINUTES=1440

# === CORS ===
CORS_ORIGINS=*
